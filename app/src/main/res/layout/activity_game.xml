<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fitsSystemWindows="true">

    <!-- ===== THÔNG TIN NGƯỜI CHƠI ĐEN (trên cùng) ===== -->
    <LinearLayout
        android:id="@+id/layoutPlayerBlack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#16213E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgBlackAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/piece_black_king"
            android:padding="4dp"
            android:background="@drawable/avatar_bg"
            android:contentDescription="Black player" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvPlayerBlackName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Người chơi 2 (Đen)"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:id="@+id/imgBlackTurnIndicator"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/turn_indicator_inactive" />

                <TextView
                    android:id="@+id/tvBlackStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang chờ"
                    android:textColor="#8899AA"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvTimerBlack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/timer_bg_inactive"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp" />
    </LinearLayout>

    <!-- ===== THÔNG TIN TRẬN ĐẤU ===== -->
    <LinearLayout
        android:id="@+id/layoutMatchInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="6dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutPlayerBlack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvMatchStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚔ Lượt của Trắng"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ===== BÀN CỜ ===== -->
    <!--
        boardWrapper is a square (1:1) that fills the space between the two
        player bars. The GridView sits inside with no padding so the adapter's
        parentWidth/8 math gives perfectly square cells.
    -->
    <FrameLayout
        android:id="@+id/boardWrapper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutMatchInfo"
        app:layout_constraintBottom_toTopOf="@id/layoutPlayerWhite"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1">

        <GridView
            android:id="@+id/chessBoard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:numColumns="8"
            android:verticalSpacing="0dp"
            android:horizontalSpacing="0dp"
            android:stretchMode="columnWidth"
            android:scrollbars="none" />

    </FrameLayout>

    <!-- ===== THÔNG TIN NGƯỜI CHƠI TRẮNG ===== -->
    <LinearLayout
        android:id="@+id/layoutPlayerWhite"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#16213E"
        app:layout_constraintBottom_toTopOf="@id/layoutControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgWhiteAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/piece_white_rook"
            android:padding="4dp"
            android:background="@drawable/avatar_bg_active"
            android:contentDescription="White player" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvPlayerWhiteName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Người chơi 1 (Trắng)"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:id="@+id/imgWhiteTurnIndicator"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/turn_indicator_active" />

                <TextView
                    android:id="@+id/tvWhiteStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang đi"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvTimerWhite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00"
            android:textColor="#1A1A2E"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/timer_bg_active"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp" />
    </LinearLayout>

    <!-- ===== THANH ĐIỀU KHIỂN (dưới cùng) ===== -->
    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:paddingHorizontal="8dp"
        android:background="#0F3460"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnUndoMove"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:text="↩ Hoàn tác"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_control"
            android:enabled="false" />

        <Button
            android:id="@+id/btnHint"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:text="💡 Gợi ý"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_control" />

        <Button
            android:id="@+id/btnResign"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:text="🏳 Đầu hàng"
            android:textSize="13sp"
            android:textColor="#FF5252"
            android:background="@drawable/btn_control_danger" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
