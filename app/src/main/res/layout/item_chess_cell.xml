<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cellRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Nền ô (sáng/tối / selected / check) -->
    <View
        android:id="@+id/cellBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Vòng tròn highlight nước đi hợp lệ -->
    <View
        android:id="@+id/cellHighlight"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:background="@drawable/highlight_move"
        android:visibility="gone" />

    <!-- Hình quân cờ -->
    <ImageView
        android:id="@+id/imgPiece"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:padding="3dp"
        android:scaleType="fitCenter"
        android:contentDescription="chess piece" />

    <!-- Nhãn tọa độ góc (tuỳ chọn) -->
    <TextView
        android:id="@+id/tvCellLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="1dp"
        android:textSize="7sp"
        android:textStyle="bold"
        android:visibility="gone" />

</FrameLayout>